{
  "name": "joysword-launcher",
  "version": "1.2.0",
  "private": true,
  "author": "JoySword",
  "description": "JoySword Windows game client launcher",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run typecheck && npm run build:main && npm run build:renderer",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "dist": "npm run test && npm run build && electron-builder --win nsis portable --x64"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "@types/node": "20.17.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "electron": "37.2.6",
    "electron-builder": "25.1.8",
    "typescript": "5.7.3",
    "vite": "6.1.0",
    "vitest": "3.0.5",
    "wait-on": "8.0.2"
  },
  "build": {
    "appId": "dev.joysword.launcher",
    "productName": "JoySword Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/content",
        "to": "content"
      }
    ],
    "win": {
      "signtoolOptions": {
        "publisherName": "JoySword"
      },
      "signAndEditExecutable": true,
      "icon": "public/art/joysword-launcher-icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "JoySword-Launcher-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JoySword Launcher"
    },
    "portable": {
      "artifactName": "JoySword-Launcher-Portable-${version}-${arch}.${ext}"
    }
  }
}
